{
  "expo": {
    "name": "RoadMitra Mechanic",
    "slug": "mechanic-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "The app accesses your photos to let you upload registration documents.",
        "NSCameraUsageDescription": "The app accesses your camera to let you take photos for registration documents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.prateeksen655.mechanicapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAzK4H6wmJV6pZaP1xHJBt6pUM3gJjNrQg"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload registration documents.",
          "cameraPermission": "The app accesses your camera to let you take photos for registration documents."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cfe1992e-b179-4174-948d-53e8c00f74f8"
      }
    },
    "owner": "prateeksen123"
  }
}

{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "ENVIRONMENT": "preview"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
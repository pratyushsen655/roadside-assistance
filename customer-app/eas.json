{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "ENVIRONMENT": "development"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "ENVIRONMENT": "preview"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://roadside-assistance-production-ddaf.up.railway.app",
        "ENVIRONMENT": "production"
      }
    }
  }
}

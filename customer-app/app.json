{
  "expo": {
    "name": "RoadMitra",
    "slug": "roadside-customer-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B34700"
    },
    "ios": {
      "bundleIdentifier": "com.rescueme.customer",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby mechanics and auto-fill your address.",
        "NSLocationAlwaysUsageDescription": "We need your location to track your mechanic in real time.",
        "NSCameraUsageDescription": "Camera access is needed for capturing photos of the vehicle condition.",
        "NSMicrophoneUsageDescription": "Microphone access is needed for voice messages in the in-app chat."
      }
    },
    "android": {
      "package": "com.praty.roadsideassist",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "INTERNET"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAzK4H6wmJV6pZaP1xHJBt6pUM3gJjNrQg"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-status-bar",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "e177a3b6-cd05-4fdd-823b-9c80584e9cd3"
      }
    },
    "cli": {
      "appVersionSource": "native"
    }
  },
  "cli": {
    "appVersionSource": "native"
  }
}

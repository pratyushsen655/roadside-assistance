{
  "info": {
    "name": "Roadside Assistance API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection of all API endpoints for the Roadside Assistance project. Includes auth, user, mechanic, service request, payment, chat, and admin routes."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/customer",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", "customer"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"9899001122\",\n  \"password\": \"password123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register Mechanic",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/mechanic",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", "mechanic"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Mehta\",\n  \"email\": \"rahul@example.com\",\n  \"phone\": \"9899007788\",\n  \"password\": \"password123\",\n  \"vehicleSpecializations\": [\"car\", \"bike\"]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9899001122\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.token) {",
                  "    pm.environment.set('jwt_token', json.token);",
                  "    console.log('JWT saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/users/me/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me", "avatar"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [{
                "key": "avatar",
                "type": "file",
                "src": "{{avatar_path}}"
              }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Mechanics",
      "item": [
        {
          "name": "List Nearby",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/mechanics/nearby?lat=28.6139&lng=77.2090",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mechanics", "nearby"],
              "query": [
                {"key": "lat", "value": "28.6139"},
                {"key": "lng", "value": "77.2090"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/mechanics/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mechanics", ":id"]
            }
          },
          "response": []
        },
        {
          "name": "Toggle Online Status",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mechanics/me/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mechanics", "me", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"online\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Service Requests",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [

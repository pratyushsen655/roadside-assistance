            ],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleType\": \"car\",\n  \"vehicleModel\": \"Maruti Swift\",\n  \"issueDescription\": \"Engine stalling\",\n  \"customerLocation\": {\n    \"type\": \"Point\",\n    \"coordinates\": [77.2090, 28.6139]\n  }\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Nearby Mechanics",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests/:id/nearby-mechanics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests", ":id", "nearby-mechanics"]
            }
          },
          "response": []
        },
        {
          "name": "Accept",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests/:id/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests", ":id", "accept"]
            }
          },
          "response": []
        },
        {
          "name": "Start",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests/:id/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests", ":id", "start"]
            }
          },
          "response": []
        },
        {
          "name": "Complete",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests/:id/complete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests", ":id", "complete"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/servicerequests/:id/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "servicerequests", ":id", "cancel"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/create",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "create"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceRequestId\": \"<REQUEST_ID>\",\n  \"amount\": 3500\n}"
            }
          },
          "response": []
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "verify"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"<ORDER_ID>\",\n  \"paymentId\": \"<PAYMENT_ID>\",\n  \"signature\": \"<SIGNATURE>\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/payments/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "history"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/chat/:roomId/message",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", ":roomId", "message"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello, mechanic!\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/chat/:roomId/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", ":roomId", "history"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard"]
            }
          },
          "response": []
        },
        {
          "name": "Approve Mechanic",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{jwt_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/mechanics/:id/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "mechanics", ":id", "approve"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            }
          },
          "response": []
